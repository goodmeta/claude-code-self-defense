{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/dangerous-command-guard.sh",
            "timeout": 5,
            "statusMessage": "Scanning for dangerous commands..."
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/network-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking network safety..."
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/data-exfil-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking for data exfiltration..."
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/pkg-security-check.sh",
            "timeout": 10,
            "statusMessage": "Checking package security..."
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/network-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking URL safety..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/prompt-injection-scanner.sh",
            "timeout": 5,
            "statusMessage": "Scanning for prompt injection..."
          }
        ]
      }
    ]
  }
}
